# PacerAI frontend environment variables
# Copy this file to .env.local and fill in the values.
# Set these in the Vercel dashboard for production deployments.

# Supabase project URL (public, safe to expose client-side)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous/public key (public, safe to expose client-side)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# FastAPI backend base URL
VITE_API_URL=https://your-api.railway.app

# IMPORTANT: The Supabase service-role key and JWT secret are SERVER-ONLY secrets.
# They must NEVER be placed in this file or any VITE_ variable — they would be
# bundled into the client and exposed to all users.
