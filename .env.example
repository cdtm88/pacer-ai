# Environment variables required for PacerAI backend
# Copy this file to .env and fill in the values.
# The actual .env file is gitignored and must never be committed.

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
# BACKEND ONLY: Service role key bypasses RLS — must never be included in frontend code or client-side bundles.
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret from Supabase dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=

# Anthropic
ANTHROPIC_API_KEY=
# Optional: override default model (defaults to claude-sonnet-4-5)
# ANTHROPIC_MODEL=claude-sonnet-4-5

# CORS / URLs (set to production values on Railway)
FRONTEND_URL=http://localhost:5173
BACKEND_BASE_URL=http://localhost:8000

# Google Calendar OAuth (required for calendar sync)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Fernet key for encrypting calendar tokens at rest — generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CALENDAR_FERNET_KEY=
